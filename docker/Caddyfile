{
  auto_https disable_redirects
}

:80 {
  encode gzip zstd

  header {
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
    Referrer-Policy strict-origin-when-cross-origin
    Permissions-Policy "camera=(), microphone=(), geolocation=()"
  }

  @api_routes {
    path /api/* /auth/* /health /ready /dashboard/* /transactions* /transfers* /transfer-users* /fixed-expenses* /categories* /sync/* /notification-preferences* /push/* /stats/* /admin/summary /admin/users /admin/audit-logs
  }

  handle @api_routes {
    reverse_proxy api:3000
  }

  handle_path /admin/* {
    reverse_proxy web:80
  }

  handle {
    reverse_proxy web:80
  }
}
